<?xml version="1.0" encoding="utf-8"?>
<package format="3">
  <name>kalibr2</name>
  <version>0.0.1</version>
  <description>Kalibr2 offline calibration library</description>
  <maintainer email="paul.furgale@mavt.ethz.ch">Paul Furgale</maintainer>
  <license>BSD</license>

  <buildtool_depend>ament_cmake</buildtool_depend>

  <build_depend>aslam_backend</build_depend>
  <build_depend>aslam_backend_expressions</build_depend>
  <build_depend>aslam_cameras</build_depend>
  <build_depend>aslam_cameras_april</build_depend>
  <build_depend>aslam_cv_backend</build_depend>
  <build_depend>aslam_splines</build_depend>
  <build_depend>ethz_apriltag2</build_depend>
  <build_depend>incremental_calibration</build_depend>
  <build_depend>eigen</build_depend>
  <build_depend>libopencv-dev</build_depend>
  <build_depend>simple_graph</build_depend>
  <build_depend>sm_common</build_depend>
  <build_depend>sm_kinematics</build_depend>

  <exec_depend>aslam_backend</exec_depend>
  <exec_depend>aslam_cameras</exec_depend>
  <exec_depend>aslam_cameras_april</exec_depend>
  <exec_depend>aslam_splines</exec_depend>
  <exec_depend>sm_kinematics</exec_depend>

  <build_depend>aslam_time</build_depend>
  <build_depend>aslam_cv_error_terms</build_depend>
  <export>
    <build_type>cmake</build_type>
  </export>
</package>
