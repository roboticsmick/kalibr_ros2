<?xml version="1.0"?>
<package format="3">
  <name>kalibr_imu_ros2</name>
  <version>0.0.1</version>
  <description>IMU-camera calibration for ROS2 Jazzy, ported from ETH Kalibr (original Python scripts with ROS2 bag reader)</description>
  <maintainer email="user@example.com">user</maintainer>
  <license>New BSD</license>
  <buildtool_depend>ament_cmake</buildtool_depend>
  <buildtool_depend>ament_cmake_python</buildtool_depend>
  <depend>rclpy</depend>
  <depend>rosbag2_py</depend>
  <depend>cv_bridge</depend>
  <depend>sensor_msgs</depend>
  <build_depend>python3-numpy</build_depend>
  <build_depend>python3-scipy</build_depend>
  <build_depend>python3-matplotlib</build_depend>
  <build_depend>python3-yaml</build_depend>
  <exec_depend>kalibr_errorterms</exec_depend>
  <exec_depend>aslam_backend_python</exec_depend>
  <exec_depend>aslam_cv_python</exec_depend>
  <exec_depend>aslam_cv_backend_python</exec_depend>
  <exec_depend>aslam_splines_python</exec_depend>
  <exec_depend>bsplines_python</exec_depend>
  <exec_depend>sm_python</exec_depend>
  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
